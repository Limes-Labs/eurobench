{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Limes-Labs/eurobench/tasks/schema/eurobench_task.schema.json",
  "title": "EuroBench v0.2 task shard",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "suite_id",
    "shard_id",
    "description",
    "limitations",
    "source_policy",
    "tasks"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "0.2.0"
    },
    "suite_id": {
      "type": "string",
      "const": "eurobench-v0.2"
    },
    "shard_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]+$"
    },
    "description": {
      "type": "string",
      "minLength": 20
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 10
      }
    },
    "constitution_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "url",
        "scope"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "scope": {
          "type": "string"
        }
      }
    },
    "source_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed_sources",
        "disallowed_sources",
        "notes"
      ],
      "properties": {
        "allowed_sources": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "disallowed_sources": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/task"
      }
    }
  },
  "$defs": {
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "category",
        "task_type",
        "language",
        "prompt",
        "expected_behavior",
        "expected_elements",
        "citation_expectation",
        "rubric",
        "source"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z]{2,5}-[a-z0-9-]+-[0-9]{3}$"
        },
        "category": {
          "type": "string",
          "enum": [
            "italian_institutional_qa",
            "french_institutional_qa",
            "german_institutional_qa",
            "translation_fidelity",
            "constitutional_refusal"
          ]
        },
        "task_type": {
          "type": "string",
          "enum": [
            "generative_qa",
            "translation",
            "constitutional_behavior"
          ]
        },
        "language": {
          "type": "string",
          "pattern": "^[a-z]{2}(-[A-Z]{2})?$"
        },
        "prompt": {
          "type": "string",
          "minLength": 20
        },
        "context": {
          "type": "string"
        },
        "reference_answer": {
          "type": "string"
        },
        "expected_behavior": {
          "type": "string",
          "enum": [
            "answer_with_caveats",
            "translate_faithfully",
            "refuse_and_redirect",
            "comply_safely",
            "express_uncertainty"
          ]
        },
        "expected_elements": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "citation_expectation": {
          "type": "string"
        },
        "auto_checks": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "must_include_any": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "must_include_all": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "must_not_include": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "refusal_markers": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "rubric": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "correct",
            "partially_correct",
            "hallucinated",
            "over_refusal",
            "unsafe_compliance",
            "missing_citation"
          ],
          "properties": {
            "correct": {
              "type": "string"
            },
            "partially_correct": {
              "type": "string"
            },
            "hallucinated": {
              "type": "string"
            },
            "over_refusal": {
              "type": "string"
            },
            "unsafe_compliance": {
              "type": "string"
            },
            "missing_citation": {
              "type": "string"
            }
          }
        },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "license",
            "attribution"
          ],
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "synthetic",
                "public_domain",
                "open_license"
              ]
            },
            "license": {
              "type": "string"
            },
            "attribution": {
              "type": "string"
            },
            "url": {
              "type": "string",
              "format": "uri"
            }
          }
        }
      }
    }
  }
}
